      "dependencies": [
        "@tanstack/react-table",
        "@dnd-kit/core",
        "@dnd-kit/sortable",
        "@dnd-kit/modifiers",
        "@dnd-kit/utilities",
        "lucide-react"
      ],
      "registryDependencies": [
